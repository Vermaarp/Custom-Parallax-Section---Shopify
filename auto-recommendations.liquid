{% doc %}
  @prompt
    i want one people also bought  as like recently viewved prodducts, products and collections auto 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-auto-recommendations-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  .ai-auto-recommendations-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-auto-recommendations-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-auto-recommendations-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    text-align: {{ block.settings.heading_alignment }};
  }

  .ai-auto-recommendations-products-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.product_gap }}px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.scrollbar_color }} transparent;
    padding-bottom: 10px;
  }

  .ai-auto-recommendations-products-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 6px;
  }

  .ai-auto-recommendations-products-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-auto-recommendations-products-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background-color: {{ block.settings.scrollbar_color }};
    border-radius: 3px;
  }

  .ai-auto-recommendations-product-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.product_width }}px;
    min-width: {{ block.settings.product_width }}px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .ai-auto-recommendations-product-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-auto-recommendations-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: #f4f4f4;
    margin-bottom: 12px;
  }

  .ai-auto-recommendations-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    display: block;
  }

  .ai-auto-recommendations-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-auto-recommendations-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-auto-recommendations-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 8px;
    left: 8px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 4px 8px;
    font-size: 11px;
    border-radius: 3px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-auto-recommendations-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ai-auto-recommendations-vendor-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.vendor_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-auto-recommendations-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-auto-recommendations-price-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.price_size }}px;
  }

  .ai-auto-recommendations-price-regular-{{ ai_gen_id }} {
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-auto-recommendations-price-compare-{{ ai_gen_id }} {
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    font-size: 0.9em;
  }

  .ai-auto-recommendations-price-sale-{{ ai_gen_id }} {
    color: {{ block.settings.sale_price_color }};
    font-weight: 600;
  }

  .ai-auto-recommendations-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #999;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-auto-recommendations-product-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.product_width_mobile }}px;
      min-width: {{ block.settings.product_width_mobile }}px;
    }

    .ai-auto-recommendations-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<auto-recommendations-{{ ai_gen_id }}
  class="ai-auto-recommendations-{{ ai_gen_id }}"
  data-product-id="{{ product.id }}"
  data-limit="{{ block.settings.max_products }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-auto-recommendations-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-auto-recommendations-header-{{ ai_gen_id }}">
        <h2 class="ai-auto-recommendations-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="ai-auto-recommendations-products-{{ ai_gen_id }}" data-recommendations-container>
      {% if product %}
        {% assign recommendations_url = routes.product_recommendations_url | append: '?product_id=' | append: product.id | append: '&limit=' | append: block.settings.max_products | append: '&section_id=' | append: section.id %}
        
        {% comment %}Fetch product recommendations{% endcomment %}
        <div class="ai-auto-recommendations-loading-{{ ai_gen_id }}">
          Loading recommendations...
        </div>
      {% else %}
        <div class="ai-auto-recommendations-empty-{{ ai_gen_id }}">
          Product recommendations will appear here
        </div>
      {% endif %}
    </div>
  </div>
</auto-recommendations-{{ ai_gen_id }}>

<script>
  (function() {
    class AutoRecommendations{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.productId = this.dataset.productId;
        this.limit = this.dataset.limit || 8;
      }

      connectedCallback() {
        this.container = this.querySelector('[data-recommendations-container]');
        
        if (this.productId) {
          this.fetchRecommendations();
        }
        
        this.setupScrollBehavior();
      }

      async fetchRecommendations() {
        try {
          const url = `/recommendations/products.json?product_id=${this.productId}&limit=${this.limit}`;
          const response = await fetch(url);
          
          if (!response.ok) {
            throw new Error('Failed to fetch recommendations');
          }
          
          const data = await response.json();
          
          if (data.products && data.products.length > 0) {
            this.renderProducts(data.products);
          } else {
            this.showEmptyState();
          }
        } catch (error) {
          console.error('Error fetching recommendations:', error);
          this.showEmptyState();
        }
      }

      renderProducts(products) {
        const showVendor = {{ block.settings.show_vendor | json }};
        const showPrice = {{ block.settings.show_price | json }};
        const showBadges = {{ block.settings.show_badges | json }};
        
        const productsHTML = products.map(product => {
          const hasDiscount = product.compare_at_price_max > product.price_max;
          const discountPercent = hasDiscount 
            ? Math.round(((product.compare_at_price_max - product.price_max) / product.compare_at_price_max) * 100)
            : 0;
          
          const priceHTML = showPrice ? `
            <div class="ai-auto-recommendations-price-{{ ai_gen_id }}">
              ${hasDiscount ? `
                <span class="ai-auto-recommendations-price-sale-{{ ai_gen_id }}">
                  ${this.formatMoney(product.price_min)}
                </span>
                <span class="ai-auto-recommendations-price-compare-{{ ai_gen_id }}">
                  ${this.formatMoney(product.compare_at_price_max)}
                </span>
              ` : `
                <span class="ai-auto-recommendations-price-regular-{{ ai_gen_id }}">
                  ${this.formatMoney(product.price_min)}
                </span>
              `}
            </div>
          ` : '';
          
          const vendorHTML = showVendor && product.vendor ? `
            <div class="ai-auto-recommendations-vendor-{{ ai_gen_id }}">${product.vendor}</div>
          ` : '';
          
          const badgeHTML = showBadges && hasDiscount ? `
            <div class="ai-auto-recommendations-badge-{{ ai_gen_id }}">
              ${discountPercent}% off
            </div>
          ` : '';
          
          const imageHTML = product.featured_image ? `
            <img
              src="${product.featured_image}"
              alt="${this.escapeHtml(product.title)}"
              class="ai-auto-recommendations-image-{{ ai_gen_id }}"
              loading="lazy"
              width="400"
              height="400"
            >
          ` : `
            <div class="ai-auto-recommendations-image-placeholder-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 525.5 525.5">
                <path d="M324.5 212.7H203c-1.6 0-2.8 1.3-2.8 2.8V308c0 1.6 1.3 2.8 2.8 2.8h121.6c1.6 0 2.8-1.3 2.8-2.8v-92.5c0-1.6-1.3-2.8-2.9-2.8zm1.1 95.3c0 .6-.5 1.1-1.1 1.1H203c-.6 0-1.1-.5-1.1-1.1v-92.5c0-.6.5-1.1 1.1-1.1h121.6c.6 0 1.1.5 1.1 1.1V308z"/>
                <path d="M210.4 299.5H240v.1s.1 0 .2-.1h75.2v-76.2h-105v76.2zm1.8-7.2l20-24c1.6-1.9 4.3-2.1 6.2-.6l12.6 10.3 20.2-24.2c1.5-1.8 4.1-2 5.9-.6l18 15.3v-26.8h-82.9v50.6z"/>
                <circle cx="227.7" cy="244.4" r="5.4"/>
              </svg>
            </div>
          `;
          
          return `
            <a
              href="${product.url}"
              class="ai-auto-recommendations-product-{{ ai_gen_id }}"
            >
              <div class="ai-auto-recommendations-image-wrapper-{{ ai_gen_id }}">
                ${imageHTML}
                ${badgeHTML}
              </div>
              <div class="ai-auto-recommendations-info-{{ ai_gen_id }}">
                ${vendorHTML}
                <h3 class="ai-auto-recommendations-title-{{ ai_gen_id }}">${this.escapeHtml(product.title)}</h3>
                ${priceHTML}
              </div>
            </a>
          `;
        }).join('');
        
        this.container.innerHTML = productsHTML;
      }

      showEmptyState() {
        this.container.innerHTML = `
          <div class="ai-auto-recommendations-empty-{{ ai_gen_id }}">
            No recommendations available
          </div>
        `;
      }

      formatMoney(cents) {
        const amount = cents / 100;
        return new Intl.NumberFormat('{{ localization.language.iso_code }}', {
          style: 'currency',
          currency: '{{ cart.currency.iso_code }}'
        }).format(amount);
      }

      escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }

      setupScrollBehavior() {
        if (!this.container) return;
        
        let isDown = false;
        let startX;
        let scrollLeft;

        this.container.addEventListener('mousedown', (e) => {
          isDown = true;
          this.container.style.cursor = 'grabbing';
          startX = e.pageX - this.container.offsetLeft;
          scrollLeft = this.container.scrollLeft;
        });

        this.container.addEventListener('mouseleave', () => {
          isDown = false;
          this.container.style.cursor = 'grab';
        });

        this.container.addEventListener('mouseup', () => {
          isDown = false;
          this.container.style.cursor = 'grab';
        });

        this.container.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.container.offsetLeft;
          const walk = (x - startX) * 2;
          this.container.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('auto-recommendations-{{ ai_gen_id }}', AutoRecommendations{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
